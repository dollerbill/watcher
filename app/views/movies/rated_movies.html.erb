<p id="notice"><%= notice %></p>

<h1>Rated Movies</h1>


<div class="album py-5 bg-dark">
  <div class="container">
    <div class="row">
        <%= form_with url: movies_path, method: :get, model: Movie do |form| %>
          <%= form.select :streaming_service, %w[hulu netflix plex prime]%>
          <%= form.button "Filter" %>
        <% end %>

        <br>
        <%= button_to "All movies", rated_movies_path, method: :get %>
    </div>

    <div class="row">
    <% @movies.each do |movie| %>
      <div class="col-md-4">
        <div class="card mb-4 shadow-sm">
          <img src="<%= movie.image_url %>" style="max-height: 600px;" />
          <div class="card-body">
            <p class="card-text"><%= movie.name %></p>
            <p class="card-text">Available on <%= movie.streaming_service.capitalize %> </p>
            <div class="d-flex justify-content-between align-items-center">
              <div class="btn-group">
                <button type="button" class="btn btn-sm btn-outline-secondary">
<!--                  TODO: Which is better-->
                  <%= link_to 'Details', movie_path(movie) %>
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary">
                  <a href="/movies/<%= movie.id%> ">Show</a>
                </button>
              </div>
              <small class="text-muted"><%= movie.length %> minutes</small>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    </div>
  </div>
</div>
